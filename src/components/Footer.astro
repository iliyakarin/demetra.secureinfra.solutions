---
// Footer.astro
const currentYear = new Date().getFullYear();

const links = {
  'Product': [
    { label: 'Platform',      href: '#platform'  },
    { label: 'Hardware',      href: '#hardware'  },
    { label: 'Open Source',   href: '#' },
    { label: 'Documentation', href: '#' },
    { label: 'Changelog',     href: '#'          },
  ],
  'Company': [
    { label: 'About',         href: '#team'      },
    { label: 'Careers',       href: '#'          },
    { label: 'Blog',          href: '#'          },
    { label: 'Contact',       href: '#cta'       },
  ],
  'Legal': [
    { label: 'Privacy Policy',    href: '#' },
    { label: 'Terms of Service',  href: '#' },
    { label: 'Security',          href: '#' },
    { label: 'GDPR',              href: '#' },
  ],
};
---

<footer style="background:var(--color-slate);border-top:1px solid var(--color-border);">
  <div class="max-w-content container-pad mx-auto" style="padding-block:4rem;">
    <!-- Top: Logo + link columns -->
    <div class="grid md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div>
        <a href="#hero" class="flex items-center gap-3 mb-4" aria-label="Demetra IoT">
          <img src="/logo.png" alt="Demetra IoT" style="width:36px;height:36px;object-fit:contain;" />
          <div>
            <span class="font-bold text-lg gradient-text">Demetra</span>
            <span class="block text-xs text-muted font-mono" style="letter-spacing:0.15em;">IoT PLATFORM</span>
          </div>
        </a>
        <p style="font-size:0.875rem;color:var(--color-muted);line-height:1.7;margin-bottom:1.25rem;">
          Operational AI for profitable, sustainable farming. Edge-first, open-source, built by infrastructure veterans.
        </p>
        <!-- Social -->
        <div style="display:flex;gap:0.75rem;">
          {[
            { label:'GitHub (Coming Soon)', href:'#', icon:'<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>' },
            { label:'LinkedIn', href:'#', icon:'<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>' },
            { label:'Twitter / X', href:'#', icon:'<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>' },
          ].map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              style="width:36px;height:36px;border-radius:9px;background:rgba(0,0,0,0.04);border:1px solid var(--color-border);display:inline-flex;align-items:center;justify-content:center;color:var(--color-muted);transition:all 0.2s ease;"
              onmouseover="this.style.color='var(--color-leaf)';this.style.borderColor='rgba(127,163,129,0.5)'"
              onmouseout="this.style.color='var(--color-muted)';this.style.borderColor='var(--color-border)'"
              set:html={s.icon}
            ></a>
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <h4 style="font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text);margin-bottom:1rem;">{group}</h4>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            {items.map(item => (
              <li>
                <a
                  href={item.href}
                  style="font-size:0.875rem;color:var(--color-muted);text-decoration:none;transition:color 0.2s ease;"
                  onmouseover="this.style.color='var(--color-leaf)'"
                  onmouseout="this.style.color='var(--color-muted)'"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="divider"></div>

    <!-- Bottom bar -->
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;padding-top:1.75rem;">
      <p style="font-size:0.8125rem;color:var(--color-muted);">
        © {currentYear} Demetra IoT, SecureInfra Solutions. All rights reserved.
      </p>
      <div style="display:flex;align-items:center;gap:1rem;">
        <span class="badge" style="font-size:0.625rem;">
          <span class="pulse-dot" style="width:6px;height:6px;"></span>
          Platform Status: Operational
        </span>
        <span style="font-size:0.75rem;color:var(--color-muted);font-family:var(--font-mono);">v2.x — Open Source Linux</span>
      </div>
    </div>
  </div>
</footer>

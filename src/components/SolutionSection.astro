---
// SolutionSection.astro
const oldWay = [
  'Collect data → export CSV → review weekly',
  'Manually adjust irrigation schedules',
  'React to crop disease after it spreads',
  'Guessing optimal harvest windows',
  'Siloed sensors, no automation layer',
];

const demetraWay = [
  'Edge AI processes sensor data in < 50ms',
  'Irrigation valve closes automatically on threshold',
  'Disease risk predicted 72 hours early',
  'AI-optimized harvest scheduling, zone by zone',
  'Unified hub executes actions across all hardware',
];
---

<section id="solution" class="section-pad">
  <div class="max-w-content container-pad mx-auto">
    <div class="text-center" style="max-width:680px;margin-inline:auto;margin-bottom:5rem;">
      <div class="section-label" style="justify-content:center;">
        <span class="badge">The Solution</span>
      </div>
      <h2 style="font-size:clamp(2rem,4.5vw,3rem);font-weight:800;line-height:1.15;letter-spacing:-0.025em;margin-bottom:1rem;">
        Operational AI:<br />
        <span class="gradient-text">From Insight to Action in Milliseconds</span>
      </h2>
      <p style="font-size:1.0625rem;color:var(--color-muted);line-height:1.75;">
        Traditional farm software shows you what happened. Demetra IoT changes what happens next — automatically, at the hardware level.
      </p>
    </div>

    <!-- Comparison Table -->
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      <!-- Old Way -->
      <div class="glass" style="padding:2.5rem;border-color:rgba(239,68,68,0.2);">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:2rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(239,68,68,0.9)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </div>
          <span style="font-weight:700;font-size:1.0625rem;">Traditional Analytics Platform</span>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1rem;">
          {oldWay.map(item => (
            <li style="display:flex;align-items:flex-start;gap:0.875rem;font-size:0.9375rem;color:var(--color-muted);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(239,68,68,0.7)" stroke-width="2" stroke-linecap="round" style="flex-shrink:0;margin-top:2px;" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Demetra Way -->
      <div class="gradient-border" style="padding:2.5rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:2rem;">
          <div style="width:36px;height:36px;border-radius:10px;background:rgba(62,207,142,0.15);display:flex;align-items:center;justify-content:center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-leaf)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <span class="gradient-text" style="font-weight:700;font-size:1.0625rem;">Demetra Operational AI</span>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1rem;">
          {demetraWay.map(item => (
            <li style="display:flex;align-items:flex-start;gap:0.875rem;font-size:0.9375rem;color:var(--color-text);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-leaf)" stroke-width="2" stroke-linecap="round" style="flex-shrink:0;margin-top:2px;" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- How it works flow -->
    <div style="text-align:center;margin-bottom:3rem;">
      <h3 style="font-size:1.375rem;font-weight:700;margin-bottom:2.5rem;">How the AI Loop Works</h3>
    </div>
    <div class="grid md:grid-cols-4 gap-4">
      {[
        { n:'01', title:'Sense', body:'Zero vendor lock. Connect any sensor via LoRa, MQTT, or ZigBee. If you can connect it to the node, it streams to the SmartHub—open, agnostic, and limitless.', icon:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>' },
        { n:'02', title:'Decide', body:'The on-device AI engine processes patterns in real time — locally, with no cloud dependency. Decisions happen in under 50 milliseconds.', icon:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2M15 20v2M2 15h2M20 15h2"/></svg>' },
        { n:'03', title:'Act', body:'Commands execute directly on hardware — valves, HVAC, LED lighting, dosing pumps. Zero human intervention required. Every action is logged.', icon:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>' },
        { n:'04', title:'Learn', body:'Every action outcome feeds back into the model. The AI continuously refines its strategy — your operation gets smarter every harvest cycle.', icon:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>' },
      ].map((step, i) => (
        <div class={`glass hover-lift p-6 text-center delay-${i + 1}`} style="animation:fadeUp 0.7s ease both;">
          <div style="font-family:var(--font-mono);font-size:0.6875rem;color:var(--color-leaf);letter-spacing:0.1em;margin-bottom:1rem;">{step.n}</div>
          <div style="display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:14px;background:rgba(62,207,142,0.1);color:var(--color-leaf);margin-bottom:1rem;" set:html={step.icon}></div>
          <h4 style="font-size:1.0625rem;font-weight:700;margin-bottom:0.625rem;">{step.title}</h4>
          <p style="font-size:0.875rem;color:var(--color-muted);line-height:1.65;">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
// TeamSection.astro
const expertise = [
  { area: 'IoT & Embedded Systems',    years: '14+', desc: 'From ESP32 firmware to industrial SCADA integrations.' },
  { area: 'Cloud Infrastructure',      years: '12+', desc: 'Multi-region, zero-downtime deployments at scale.' },
  { area: 'Machine Learning / AI',     years: '8+',  desc: 'Edge inference, time-series forecasting, anomaly detection.' },
  { area: 'AgTech & Controlled Environments', years: '7+', desc: 'Deep domain knowledge of CEA, hydroponics, and vertical farming.' },
];

const values = [
  { emoji: '🔓', title: 'Radically Open', body: 'We open-source everything we can. Your operation deserves full visibility into the stack.' },
  { emoji: '⚡', title: 'Speed Over Perfection', body: 'We ship, iterate, and respond. Your feedback goes into the next sprint, not a wishlist.' },
  { emoji: '🌱', title: 'Grower-First', body: 'Every product decision is validated against real grower outcomes, not demo theater.' },
];
---

<section id="team" class="section-pad">
  <div class="max-w-content container-pad mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Who we are -->
      <div>
        <div class="section-label">
          <span class="badge">The Team</span>
        </div>
        <h2 style="font-size:clamp(2rem,4vw,2.75rem);font-weight:800;line-height:1.15;letter-spacing:-0.025em;margin-bottom:1.25rem;">
          Built by<br />
          <span class="gradient-text">Infrastructure Veterans</span>
        </h2>
        <p style="font-size:1.0625rem;color:var(--color-muted);line-height:1.75;margin-bottom:2.5rem;">
          Demetra was founded by engineers who spent 14+ years building mission-critical IoT systems for enterprise and defense environments. We got tired of watching farmers manage their operations with tools designed for software dashboards — so we built hardware that actually does the work.
        </p>

        <!-- Expertise list -->
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {expertise.map(e => (
            <div class="glass" style="padding:1.25rem 1.5rem;display:flex;align-items:center;gap:1.25rem;">
              <div style="text-align:center;min-width:52px;">
                <div class="gradient-text" style="font-size:1.5rem;font-weight:800;line-height:1;">{e.years}</div>
                <div style="font-size:0.625rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.08em;">years</div>
              </div>
              <div style="width:1px;height:40px;background:var(--color-border);flex-shrink:0;"></div>
              <div>
                <div style="font-size:0.9375rem;font-weight:600;margin-bottom:0.25rem;">{e.area}</div>
                <div style="font-size:0.8125rem;color:var(--color-muted);">{e.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Values -->
      <div>
        <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:1.75rem;">How We Build</h3>
        <div style="display:flex;flex-direction:column;gap:1.25rem;margin-bottom:2.5rem;">
          {values.map(v => (
            <div class="gradient-border" style="padding:1.75rem;">
              <div style="font-size:1.75rem;margin-bottom:0.875rem;">{v.emoji}</div>
              <h4 style="font-size:1.0625rem;font-weight:700;margin-bottom:0.5rem;">{v.title}</h4>
              <p style="font-size:0.9rem;color:var(--color-muted);line-height:1.7;">{v.body}</p>
            </div>
          ))}
        </div>

        <!-- Origin story callout -->
        <div class="glass" style="padding:2rem;border-left:3px solid var(--color-leaf);">
          <p style="font-size:0.9375rem;color:var(--color-muted);line-height:1.8;font-style:italic;">
            "We built security infrastructure for banks and data centers. When we visited a 10,000 m² cannabis greenhouse and saw the operator manually checking sensor readings every 4 hours on a clipboard, we knew exactly what to build."
          </p>
          <p style="font-size:0.8125rem;color:var(--color-muted);margin-top:0.875rem;font-style:normal;">— Co-Founder, Demetra IoT</p>
        </div>
      </div>
    </div>
  </div>
</section>
